config settings 'settings'
	option enabled '0'
	option mode 'ap'
	option radio 'all'
	option mesh_no_rebroadcast '0'
	# Internal ownership flag: set to 1 only when PUMP enabled
	# gluon.wireless.preserve_channels itself.
	option preserve_channels '0'
	# Internal keys named iface_*_disabled are created while STA mode disables
	# other wifi-ifaces on the selected radio and are removed again on restore.
