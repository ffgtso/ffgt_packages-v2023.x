config settings 'settings'
	option enabled '0'
	option mode 'ap'
	option radio 'all'
	option mesh_no_rebroadcast '0'
	# Internal ownership flag: set to 1 only when PUMP enabled
	# gluon.wireless.preserve_channels itself.
	option preserve_channels '0'

	# WiFi uplink: use an upstream WLAN as Gluon's WAN replacement.
	option uplink_enabled '0'
	option uplink_radio ''
	option uplink_ssid ''
	option uplink_bssid ''
	# 1: use only uplink_bssid; 0: allow any AP with the selected SSID.
	option uplink_bssid_lock '1'
	option uplink_encryption 'auto'
	option uplink_key ''
	# Internal ownership flag for the dedicated DHCP network interface used by
	# the WiFi uplink. Older package versions used uplink_gluon_iface; it is
	# cleaned up automatically.
	option uplink_network_iface '0'

	# Internal keys named iface_*_disabled are created while an exclusive
	# PUMP STA or WiFi uplink radio disables other wifi-ifaces on the selected
	# radio and are removed again on restore.
