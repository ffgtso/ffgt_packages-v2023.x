#!/bin/sh

# Tunneldigger may start before the WiFi uplink STA netdev exists.  Config Mode
# only writes UCI; the runtime correction belongs here, when pump_wan is up and
# the pumpwan device can exist.

[ "$INTERFACE" = "pump_wan" ] || exit 0
case "$ACTION" in
	ifup|ifupdate) ;;
	*) exit 0 ;;
esac

[ "$(uci -q get pump.settings.uplink_enabled)" = "1" ] || exit 0

ifname="$(uci -q get wireless.pump_uplink.ifname)"
[ -n "$ifname" ] || ifname="pumpwan"
[ -d "/sys/class/net/$ifname" ] || exit 0

/usr/lib/gluon/pump/tunneldigger-bind restart >/dev/null 2>&1 &

exit 0
