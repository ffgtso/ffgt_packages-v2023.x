#!/usr/bin/lua

local iwinfo = require 'iwinfo'
local uci = require('simple-uci').cursor()
local wireless = require 'gluon.wireless'
local pump = require 'gluon.pump'

local function ensure_settings()
	if not uci:get('pump', 'settings') then
		uci:section('pump', 'settings', 'settings', {
			enabled = false,
			mode = 'ap',
			radio = 'all',
			mesh_no_rebroadcast = false,
			preserve_channels = false,
			uplink_enabled = false,
			uplink_bssid_lock = true,
			uplink_encryption = 'auto',
			uplink_htmode = 'auto',
			uplink_powersave = false,
		})
	end
end

local function ensure_gluon_wireless()
	if not uci:get('gluon', 'wireless') then
		uci:section('gluon', 'wireless', 'wireless', {})
	end
end

local function ensure_network_wan()
	if not uci:get('network', 'wan') then
		uci:section('network', 'interface', 'wan', {
			proto = 'dhcp',
		})
	end
end


local function option_as_list(value)
	if type(value) == 'table' then
		return value
	end
	if value == nil or value == '' then
		return {}
	end

	local values = {}
	for item in tostring(value):gmatch('%S+') do
		values[#values + 1] = item
	end
	return values
end

local function add_list_unique(config, section, option, value)
	local values = option_as_list(uci:get(config, section, option))
	for _, existing in ipairs(values) do
		if existing == value then
			return
		end
	end
	values[#values + 1] = value
	uci:set_list(config, section, option, values)
end

local function remove_list_value(config, section, option, value)
	local values = option_as_list(uci:get(config, section, option))
	local new_values = {}
	local changed = false

	for _, existing in ipairs(values) do
		if existing == value then
			changed = true
		else
			new_values[#new_values + 1] = existing
		end
	end

	if not changed then
		return
	end

	if #new_values == 0 then
		uci:delete(config, section, option)
	else
		uci:set_list(config, section, option, new_values)
	end
end

local function ensure_wifi_uplink_network()
	local name = pump.uplink_network_name()
	local name6 = pump.uplink_network6_name()

	-- Do not register pumpwan as a Gluon uplink role and do not add it to
	-- network.wan. Gluon builds wan as br-wan; a normal 802.11 station cannot
	-- be enslaved into a bridge without 4addr/WDS, and mac80211 rejects that as
	-- BRIDGE_NOT_ALLOWED. Instead use a dedicated L3 DHCP interface that gets
	-- its device from the wifi-iface's network option.
	remove_list_value('network', 'wan', 'ifname', pump.uplink_ifname())

	local legacy_section = pump.uplink_gluon_iface_section()
	if uci:get('gluon', legacy_section, 'name') == pump.uplink_ifname() then
		uci:delete('gluon', legacy_section)
	end
	uci:delete('pump', 'settings', 'uplink_gluon_iface')

	if not uci:get('network', name) then
		uci:section('network', 'interface', name, {})
	end
	uci:set('network', name, 'proto', 'dhcp')
	uci:set('network', name, 'auto', '1')
	uci:set('network', name, 'peerdns', '0')
	uci:delete('network', name, 'type')
	uci:delete('network', name, 'ifname')

	if not uci:get('network', name6) then
		uci:section('network', 'interface', name6, {})
	end
	uci:set('network', name6, 'proto', 'dhcpv6')
	uci:set('network', name6, 'ifname', '@' .. name)
	uci:set('network', name6, 'ip6table', '1')
	uci:set('network', name6, 'sourcefilter', '0')
	uci:set('network', name6, 'peerdns', '0')
	uci:set('network', name6, 'reqprefix', 'no')

	uci:set('pump', 'settings', 'uplink_network_iface', '1')
end

local function remove_wifi_uplink_network_if_owned()
	local name = pump.uplink_network_name()
	local name6 = pump.uplink_network6_name()

	if uci:get_bool('pump', 'settings', 'uplink_network_iface') then
		if uci:get('network', name, 'proto') == 'dhcp' then
			uci:delete('network', name)
		end
		if uci:get('network', name6, 'ifname') == '@' .. name then
			uci:delete('network', name6)
		end
		uci:delete('pump', 'settings', 'uplink_network_iface')
	end

	-- Clean up legacy fix8/fix9/fix10 state where pumpwan was added to the
	-- Gluon WAN bridge. This cleanup is safe because only the explicit pumpwan
	-- token and the legacy iface_pumpwan section are removed.
	local section = pump.uplink_gluon_iface_section()
	if uci:get('gluon', section, 'name') == pump.uplink_ifname() then
		uci:delete('gluon', section)
	end
	remove_list_value('network', 'wan', 'ifname', pump.uplink_ifname())
	uci:delete('pump', 'settings', 'uplink_gluon_iface')
end

local function saved_tunneldigger_bind_option(section_name)
	return 'tunneldigger_' .. section_name:gsub('[^%w_]', '_') .. '_bind_interface'
end

local function foreach_tunneldigger_broker(callback)
	pcall(function()
		uci:foreach('tunneldigger', 'broker', function(section)
			if section and section['.name'] then
				callback(section)
			end
		end)
	end)
end

local function set_tunneldigger_bind_interface(device)
	local changed = false

	foreach_tunneldigger_broker(function(section)
		-- Only touch active broker sections. Disabled example/default sections are
		-- intentionally left alone.
		if section.enabled == '0' or section.enabled == false then
			return
		end

		local section_name = section['.name']
		local option = saved_tunneldigger_bind_option(section_name)
		if uci:get('pump', 'settings', option) == nil then
			local current = uci:get('tunneldigger', section_name, 'bind_interface')
			uci:set('pump', 'settings', option, current == nil and 'absent' or tostring(current))
		end

		uci:set('tunneldigger', section_name, 'bind_interface', device)
		changed = true
	end)

	if changed then
		uci:set('pump', 'settings', 'tunneldigger_bind_interface', '1')
	end
end

local function restore_tunneldigger_bind_interface_if_owned()
	if not uci:get_bool('pump', 'settings', 'tunneldigger_bind_interface') then
		return
	end

	foreach_tunneldigger_broker(function(section)
		local section_name = section['.name']
		local option = saved_tunneldigger_bind_option(section_name)
		local saved = uci:get('pump', 'settings', option)
		if saved == nil then
			return
		end

		if saved == 'absent' then
			uci:delete('tunneldigger', section_name, 'bind_interface')
		else
			uci:set('tunneldigger', section_name, 'bind_interface', saved)
		end
		uci:delete('pump', 'settings', option)
	end)

	uci:delete('pump', 'settings', 'tunneldigger_bind_interface')
end


local function selected_mode()
	local mode = uci:get('pump', 'settings', 'mode')
	if mode == 'sta' then
		return 'sta'
	end

	return 'ap'
end

local function selected_radio_matches(radio_name)
	return pump.radio_selected(uci:get('pump', 'settings', 'radio') or 'all', radio_name)
end

local function best_htmode(radio_config)
	local phy = wireless.find_phy(radio_config)
	if not phy then
		return nil
	end

	local htmodelist = iwinfo.nl80211.htmodelist(phy) or {}
	local preferred_order = {
		'HE160', 'HE80', 'HE40', 'HE20',
		'VHT160', 'VHT80', 'VHT40', 'VHT20',
		'HT40', 'HT20',
	}

	for _, htmode in ipairs(preferred_order) do
		if htmodelist[htmode] then
			return htmode
		end
	end

	return nil
end

local own_preserve_channels = uci:get_bool('pump', 'settings', 'preserve_channels')

local function ensure_preserve_channels()
	ensure_gluon_wireless()
	if not uci:get_bool('gluon', 'wireless', 'preserve_channels') then
		own_preserve_channels = true
	end
	uci:set('gluon', 'wireless', 'preserve_channels', '1')
	uci:set('pump', 'settings', 'preserve_channels', own_preserve_channels and '1' or '0')
end

local function restore_site_wireless_if_owned()
	if not own_preserve_channels then
		return
	end

	uci:delete('gluon', 'wireless', 'preserve_channels')
	uci:set('pump', 'settings', 'preserve_channels', '0')
	own_preserve_channels = false
	uci:save('gluon')
	uci:save('pump')
	os.execute('/lib/gluon/upgrade/200-wireless')
end

local function saved_disabled_option(iface_name)
	return 'iface_' .. iface_name:gsub('[^%w_]', '_') .. '_disabled'
end

local function remember_and_disable_iface(iface_name)
	local option = saved_disabled_option(iface_name)
	if uci:get('pump', 'settings', option) == nil then
		local disabled = uci:get('wireless', iface_name, 'disabled')
		uci:set('pump', 'settings', option, disabled == nil and 'absent' or tostring(disabled))
	end
	uci:set('wireless', iface_name, 'disabled', '1')
end

local function restore_iface_disabled_state(iface_name)
	local option = saved_disabled_option(iface_name)
	local saved = uci:get('pump', 'settings', option)
	if saved == nil then
		return
	end

	if saved == '1' or saved == 'true' then
		uci:set('wireless', iface_name, 'disabled', '1')
	else
		-- Treat both an originally absent option and an explicit false value as
		-- enabled. Removing the option keeps the resulting wireless config close
		-- to Gluon's generated defaults.
		uci:delete('wireless', iface_name, 'disabled')
	end

	uci:delete('pump', 'settings', option)
end

local function set_non_pump_ifaces_disabled(radio_name, disabled)
	uci:foreach('wireless', 'wifi-iface', function(iface)
		local iface_name = iface['.name']
		if iface.device ~= radio_name then
			return
		end
		if iface_name == pump.iface_name(radio_name) then
			return
		end

		if disabled then
			remember_and_disable_iface(iface_name)
		else
			restore_iface_disabled_state(iface_name)
		end
	end)
end

local function set_radio_exclusive(radio_name, keep_iface_name)
	uci:foreach('wireless', 'wifi-iface', function(iface)
		local iface_name = iface['.name']
		if iface.device ~= radio_name then
			return
		end
		if iface_name == keep_iface_name then
			return
		end

		remember_and_disable_iface(iface_name)
	end)
end

local function restore_all_saved_ifaces()
	uci:foreach('wireless', 'wifi-iface', function(iface)
		local iface_name = iface['.name']
		if iface_name then
			restore_iface_disabled_state(iface_name)
		end
	end)
end

local function apply_radio_settings(radio)
	local radio_name = radio['.name']
	local mode = selected_mode()

	ensure_preserve_channels()

	if mode == 'sta' then
		-- The station side shall not be pinned to a channel; it scans for any AP
		-- with the generated PUMP SSID and negotiates channel/width with it.
		uci:set('wireless', radio_name, 'channel', 'auto')
	else
		local channel = uci:get('pump', 'settings', radio_name .. '_channel') or uci:get('wireless', radio_name, 'channel') or 'auto'
		uci:set('wireless', radio_name, 'channel', channel)
	end

	local htmode = uci:get('pump', 'settings', radio_name .. '_htmode')
	if htmode == nil or htmode == '' or htmode == 'auto' then
		htmode = best_htmode(radio) or uci:get('wireless', radio_name, 'htmode') or 'HT20'
	end
	uci:set('wireless', radio_name, 'htmode', htmode)
end

local function apply_uplink_radio_settings(radio)
	local radio_name = radio['.name']
	local htmode = pump.non_empty(uci:get('pump', 'settings', 'uplink_htmode')) or 'auto'

	ensure_preserve_channels()
	uci:set('wireless', radio_name, 'channel', 'auto')

	if htmode == 'auto' then
		htmode = best_htmode(radio) or uci:get('wireless', radio_name, 'htmode') or 'HT20'
	end
	uci:set('wireless', radio_name, 'htmode', htmode)
end

local function configure_network(name, enabled)
	uci:section('network', 'interface', name, {
		proto = 'gluon_mesh',
		transitive = '1',
		fixed_mtu = '1',
	})

	if uci:get_bool('pump', 'settings', 'mesh_no_rebroadcast') then
		uci:set('network', name, 'mesh_no_rebroadcast', '1')
	else
		uci:delete('network', name, 'mesh_no_rebroadcast')
	end

	if enabled then
		uci:delete('network', name, 'auto')
	else
		uci:set('network', name, 'auto', '0')
	end
end

local function configure_pump_wireless(radio, index, enabled)
	local radio_name = radio['.name']
	local name = pump.iface_name(radio_name)
	local mode = selected_mode()

	configure_network(name, enabled)

	if not enabled then
		set_non_pump_ifaces_disabled(radio_name, false)
		if uci:get('wireless', name) then
			uci:set('wireless', name, 'disabled', true)
		end
		return
	end

	-- In STA mode, the selected PUMP radio must be able to follow whichever
	-- PUMP AP it finds. Other AP/mesh VIFs on the same phy would pin the radio
	-- to their own channel, so we disable them while remembering their state.
	set_non_pump_ifaces_disabled(radio_name, mode == 'sta')

	apply_radio_settings(radio)

	local macaddr = wireless.get_wlan_mac(uci, radio, index, 3)
	if not macaddr then
		uci:set('wireless', name, 'disabled', true)
		return
	end

	uci:section('wireless', 'wifi-iface', name, {
		device = radio_name,
		network = name,
		mode = mode,
		encryption = 'sae-mixed',
		ieee80211w = '1',
		ssid = pump.ssid(),
		key = pump.key(),
		macaddr = macaddr,
		ifname = pump.ifname(radio_name),
		disabled = false,
	})
end

local function normalize_uplink_encryption(encryption)
	encryption = pump.non_empty(encryption) or 'psk2'
	if encryption == 'auto' then
		return 'psk2'
	end
	if encryption == 'psk3-mixed' then
		return 'sae-mixed'
	end
	return encryption
end

local function set_uplink_pmf(name, encryption)
	if encryption == 'sae' then
		uci:set('wireless', name, 'ieee80211w', '2')
	elseif encryption == 'sae-mixed' or encryption == 'psk3-mixed' then
		uci:set('wireless', name, 'ieee80211w', '1')
	else
		uci:delete('wireless', name, 'ieee80211w')
	end
end

local function configure_wifi_uplink(radio, index, enabled)
	local radio_name = radio and radio['.name'] or nil
	local name = pump.uplink_iface_name()

	if not enabled or not radio_name then
		if uci:get('wireless', name) then
			uci:set('wireless', name, 'disabled', true)
		end
		remove_wifi_uplink_network_if_owned()
		restore_tunneldigger_bind_interface_if_owned()
		return
	end

	ensure_wifi_uplink_network()
	set_tunneldigger_bind_interface(pump.uplink_ifname())
	set_radio_exclusive(radio_name, name)
	apply_uplink_radio_settings(radio)

	-- Do not force a synthetic MAC address for the WAN STA. Some DBDC
	-- drivers/targets reject additional station VIFs when the requested MAC
	-- address collides with another generated Gluon interface or is outside the
	-- driver's accepted address mask. Let mac80211 pick the netdev address; the
	-- WAN bridge keeps its own configured MAC address.

	local ssid = uci:get('pump', 'settings', 'uplink_ssid')
	local bssid = pump.non_empty(uci:get('pump', 'settings', 'uplink_bssid'))
	local bssid_lock = pump.uplink_bssid_locked()
	local encryption = normalize_uplink_encryption(uci:get('pump', 'settings', 'uplink_encryption'))
	uci:set('pump', 'settings', 'uplink_encryption', encryption)

	uci:section('wireless', 'wifi-iface', name, {
		device = radio_name,
		network = pump.uplink_network_name(),
		mode = 'sta',
		encryption = encryption,
		ssid = ssid,
		ifname = pump.uplink_ifname(),
		powersave = uci:get_bool('pump', 'settings', 'uplink_powersave') and '1' or '0',
		disabled = false,
	})

	uci:delete('wireless', name, 'macaddr')

	if bssid_lock and pump.uplink_bssid_is_valid(bssid) then
		uci:set('wireless', name, 'bssid', bssid)
	else
		-- Without a fixed BSSID, wpa_supplicant may associate with any AP that
		-- advertises the configured SSID and compatible encryption.
		uci:delete('wireless', name, 'bssid')
	end

	if pump.encryption_uses_key(encryption) then
		uci:set('wireless', name, 'key', uci:get('pump', 'settings', 'uplink_key'))
	else
		uci:delete('wireless', name, 'key')
	end

	set_uplink_pmf(name, encryption)
end

ensure_settings()

-- Clear stale exclusive-radio disables first. Active exclusive modes will
-- immediately save and apply their current disable set again below.
restore_all_saved_ifaces()

local pump_enabled = uci:get_bool('pump', 'settings', 'enabled') and pump.config_is_valid()
local uplink_enabled = uci:get_bool('pump', 'settings', 'uplink_enabled') and pump.uplink_config_is_valid()
local uplink_radio = pump.non_empty(uci:get('pump', 'settings', 'uplink_radio'))

if not pump_enabled and not uplink_enabled then
	restore_site_wireless_if_owned()
	remove_wifi_uplink_network_if_owned()
end

local uplink_radio_config = nil
local uplink_radio_index = nil

wireless.foreach_radio(uci, function(radio, index)
	local radio_name = radio['.name']
	local radio_is_uplink = uplink_enabled and uplink_radio == radio_name

	if radio_is_uplink then
		uplink_radio_config = radio
		uplink_radio_index = index
	end

	configure_pump_wireless(radio, index, pump_enabled and selected_radio_matches(radio_name) and not radio_is_uplink)
end)

configure_wifi_uplink(uplink_radio_config, uplink_radio_index, uplink_enabled)

uci:save('pump')
uci:save('gluon')
uci:save('network')
uci:save('wireless')
pcall(function() uci:save('tunneldigger') end)
